---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="BelloTreno - Infomobilità" pageScripts={["/scripts/infomobilita.js"]}>
    <Fragment slot="head"></Fragment>

    <div class="container">
        <div class="text-center mt-10 mb-6">
            <h1 class="text-[2.5rem] font-bold mb-6 text-primary"
                data-i18n="nav_infomobilita">出行信息</h1>

            <div class="infomobilita-controls flex flex-col items-center gap-6">
                <div class="flex justify-center mx-auto w-[480px] max-w-full bg-base-200/50 p-1 rounded-full border border-base-200 shadow-sm backdrop-blur">
                    <button id="modeUpdatesBtn" class="board-tab active flex-1 flex items-center justify-center gap-1.5 py-2 px-4 text-sm font-medium rounded-full cursor-pointer transition-all"
                        onclick="switchInfoMode('updates')">
                        <span class="material-symbols-outlined text-[1.25rem]">dynamic_feed</span>
                        <span data-i18n="info_updates">实时更新</span>
                    </button>
                    <button id="modeNoticesBtn" class="board-tab flex-1 flex items-center justify-center gap-1.5 py-2 px-4 text-sm font-medium rounded-full cursor-pointer transition-all" 
                        onclick="switchInfoMode('notices')">
                        <span class="material-symbols-outlined text-[1.25rem]">campaign</span>
                        <span data-i18n="info_notices">旅行者须知</span>
                    </button>
                </div>

                <div class="dropdown w-[480px] max-w-full mx-auto" id="regionDropdown">
                    <div tabindex="0" role="button" class="btn btn-lg w-full bg-base-100 border border-base-300 focus:outline-none focus:border-primary transition-all text-base-content shadow-sm rounded-full flex justify-center hover:bg-base-200/50 font-normal h-14 min-h-[3.5rem]">
                        <span id="regionBtnText" data-i18n="region_all" class="text-[1.125rem]">所有大区</span>
                        <span class="material-symbols-outlined absolute right-5 text-base-content/50">expand_more</span>
                    </div>
                    <ul tabindex="0" class="dropdown-content z-[2] menu p-2 shadow-lg bg-base-100 border border-base-200 rounded-box w-full max-h-64 flex-nowrap overflow-y-auto mt-2">
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_all" onclick="changeDropdownRegion('all', this.textContent, 'region_all')">所有大区</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_abruzzo" onclick="changeDropdownRegion('abruzzo', this.textContent, 'region_abruzzo')">Abruzzo</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_basilicata" onclick="changeDropdownRegion('basilicata', this.textContent, 'region_basilicata')">Basilicata</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_calabria" onclick="changeDropdownRegion('calabria', this.textContent, 'region_calabria')">Calabria</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_campania" onclick="changeDropdownRegion('campania', this.textContent, 'region_campania')">Campania</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_emilia_romagna" onclick="changeDropdownRegion('emilia_romagna', this.textContent, 'region_emilia_romagna')">Emilia Romagna</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_friuli_venezia_giulia" onclick="changeDropdownRegion('friuli_venezia_giulia', this.textContent, 'region_friuli_venezia_giulia')">Friuli Venezia Giulia</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_lazio" onclick="changeDropdownRegion('lazio', this.textContent, 'region_lazio')">Lazio</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_liguria" onclick="changeDropdownRegion('liguria', this.textContent, 'region_liguria')">Liguria</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_lombardia" onclick="changeDropdownRegion('lombardia', this.textContent, 'region_lombardia')">Lombardia</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_marche" onclick="changeDropdownRegion('marche', this.textContent, 'region_marche')">Marche</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_molise" onclick="changeDropdownRegion('molise', this.textContent, 'region_molise')">Molise</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_piemonte" onclick="changeDropdownRegion('piemonte', this.textContent, 'region_piemonte')">Piemonte</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_puglia" onclick="changeDropdownRegion('puglia', this.textContent, 'region_puglia')">Puglia</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_sardegna" onclick="changeDropdownRegion('sardegna', this.textContent, 'region_sardegna')">Sardegna</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_sicilia" onclick="changeDropdownRegion('sicilia', this.textContent, 'region_sicilia')">Sicilia</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_toscana" onclick="changeDropdownRegion('toscana', this.textContent, 'region_toscana')">Toscana</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_trentino_alto_adige" onclick="changeDropdownRegion('trentino_alto_adige', this.textContent, 'region_trentino_alto_adige')">Trentino Alto Adige</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_umbria" onclick="changeDropdownRegion('umbria', this.textContent, 'region_umbria')">Umbria</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_valle_d_aosta" onclick="changeDropdownRegion('valle_d_aosta', this.textContent, 'region_valle_d_aosta')">Valle d'Aosta</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-i18n="region_veneto" onclick="changeDropdownRegion('veneto', this.textContent, 'region_veneto')">Veneto</a></li>
                    </ul>
                </div>
            </div>

            <div id="rssResults" class="rss-container mt-10 text-left">
                <div id="infoLoading" style="text-align: center; padding: 40px; display: none;">
                    <span class="loading loading-spinner loading-lg text-primary"></span>
                </div>
                <div id="rssContent"></div>
            </div>
        </div>
    </div>
</BaseLayout>
