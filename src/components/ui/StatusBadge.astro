---
interface Props {
  tone?: 'neutral' | 'info' | 'success' | 'warning' | 'danger';
  icon?: string;
  class?: string;
  [key: string]: unknown;
}

const { tone = 'neutral', icon, class: className = '', ...attrs } = Astro.props;
---

<span {...attrs} data-slot="badge" class:list={['bt-status-badge', `bt-status-${tone}`, className]}>
  {icon && <span class="material-symbols-outlined" aria-hidden="true">{icon}</span>}
  <slot />
</span>
