---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="BelloTreno" pageScripts={["/scripts/station.js", "/scripts/main.js"]}>
    <Fragment slot="head"></Fragment>
    <div class="container">
        <div class="text-center mt-10 mb-6">
            <a href="#" class="inline-block hover:opacity-80 transition-opacity" onclick="goHome(); return false;">
                <h1 class="text-[2.5rem] font-bold mb-4 text-primary">BelloTreno</h1>
            </a>

            <div class="flex justify-center mx-auto mb-4 w-64 bg-base-200/50 p-1 rounded-full border border-base-200 shadow-sm backdrop-blur">
                <button id="modeTrainBtn" class="mode-button mode-left active relative flex-1 flex items-center justify-center gap-1.5 py-2 px-4 text-sm font-medium rounded-full cursor-pointer transition-all" onclick="switchSearchMode('train')">
                    <span class="material-symbols-outlined text-[1.25rem]">train</span>
                    <span data-i18n="mode_train">车次</span>
                </button>
                <button id="modeStationBtn" class="mode-button mode-right relative flex-1 flex items-center justify-center gap-1.5 py-2 px-4 text-sm font-medium rounded-full cursor-pointer transition-all" onclick="switchSearchMode('station')">
                    <span class="material-symbols-outlined text-[1.25rem]">location_on</span>
                    <span data-i18n="mode_station">车站</span>
                </button>
            </div>

            <div class="relative w-full max-w-2xl mx-auto group">
                <span class="material-symbols-outlined absolute left-5 top-1/2 -translate-y-1/2 text-[1.5rem] text-base-content/50 pointer-events-none group-focus-within:text-primary transition-colors z-10" id="searchIcon">train</span>
                <input type="text" id="trainSearch" class="input shadow-sm w-full pl-14 py-6 text-lg bg-base-100 border-base-300 focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/20 transition-all text-base-content placeholder-base-content/40 rounded-full" placeholder="" autocomplete="off" />
            </div>

            <div id="recentSearchesContainer" class="recent-searches-container" style="display: none;">
                <div class="recent-searches-label">
                    <span class="material-symbols-outlined">history</span>
                    <span data-i18n="recent_searches">最近搜索</span>
                </div>
                <div id="recentSearchesChips" class="recent-searches-chips"></div>
            </div>
        </div>

        <div id="disambiguation">
            <h3 style="margin-top:0;" class="text-primary" data-i18n="disambiguation_title">检测到多个班次，请选择：</h3>
            <div id="choicesList"></div>
        </div>

        <div id="results">
            <div id="trainCard" class="train-header"></div>
            <div class="timeline-container">
                <div id="timelineBody"></div>
            </div>
        </div>
    </div>
</BaseLayout>
