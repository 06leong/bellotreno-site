---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';
import {
    DEFAULT_LOCALE,
    LOCALES,
    alternatePath,
    htmlLang,
    localeFromPath,
    normalizeLocale,
    ogLocale,
    type Locale,
} from '../lib/i18n';
import '../styles/global.css';

interface Props {
    title: string;
    description?: string;
    pageScripts?: string[];
    locale?: Locale;
}

const SITE_URL = 'https://bellotreno.org';
const OG_IMAGE  = `${SITE_URL}/og-image.png`;
const BUILD_ID = (
    import.meta.env.PUBLIC_BUILD_ID
    || process.env.CF_PAGES_COMMIT_SHA
    || process.env.CF_PAGES_DEPLOYMENT_ID
    || Date.now().toString(36)
).slice(0, 16);
const withBuildVersion = (src: string) => `${src}${src.includes('?') ? '&' : '?'}v=${BUILD_ID}`;
const UMAMI_SCRIPT_URL = import.meta.env.PUBLIC_UMAMI_SCRIPT_URL;
const UMAMI_WEBSITE_ID = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
const UMAMI_DOMAINS = import.meta.env.PUBLIC_UMAMI_DOMAINS || 'bellotreno.org,real.bellotreno.org';
const ENABLE_UMAMI = Boolean(UMAMI_SCRIPT_URL && UMAMI_WEBSITE_ID);

const {
    title,
    pageScripts = [],
    locale: localeProp,
    description = 'BelloTreno — Orari e stato in tempo reale dei treni italiani. Frecciarossa, Intercity, Regionali e molto altro.',
} = Astro.props;
const locale = normalizeLocale(localeProp ?? Astro.currentLocale ?? localeFromPath(Astro.url.pathname) ?? DEFAULT_LOCALE);
const currentPathWithSearch = `${Astro.url.pathname}${Astro.url.search}`;

// Canonical URL: origine + percorso corrente (senza query string / hash)
const canonicalURL = new URL(Astro.url.pathname, SITE_URL).href;
const alternateURLs = LOCALES.map((targetLocale) => ({
    locale: targetLocale,
    href: new URL(alternatePath(Astro.url.pathname, targetLocale), SITE_URL).href,
}));
---

<!DOCTYPE html>
<html lang={htmlLang[locale]} data-lang={locale}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="index, follow">
    <meta name="theme-color" content="#6a8a9f" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#082a1a" media="(prefers-color-scheme: dark)">
    <link rel="manifest" href="/site.webmanifest">

    <!-- ===== iOS PWA ===== -->
    <!-- apple-mobile-web-app-capable: 告知 Safari 以全屏 standalone 模式运行 -->
    <meta name="apple-mobile-web-app-capable" content="yes">
    <!-- black-translucent: 状态栏透明叠加在页面上，避免顶部黑条/白条 -->
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="BelloTreno">

    <!-- ===== SEO Core ===== -->
    <title>{title}</title>
    <meta name="description" content={description}>
    <link rel="canonical" href={canonicalURL}>

    <!-- ===== hreflang: one static URL per language ===== -->
    {alternateURLs.map((alternate) => (
        <link rel="alternate" hreflang={alternate.locale === 'zh' ? 'zh-Hans' : alternate.locale} href={alternate.href}>
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL('/it/', SITE_URL).href}>

    <!-- ===== Open Graph ===== -->
    <meta property="og:type"        content="website">
    <meta property="og:site_name"   content="BelloTreno">
    <meta property="og:url"         content={canonicalURL}>
    <meta property="og:title"       content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image"       content={OG_IMAGE}>
    <meta property="og:locale"      content={ogLocale[locale]}>
    {LOCALES.filter((targetLocale) => targetLocale !== locale).map((targetLocale) => (
        <meta property="og:locale:alternate" content={ogLocale[targetLocale]}>
    ))}

    <!-- ===== Twitter Card ===== -->
    <meta name="twitter:card"        content="summary_large_image">
    <meta name="twitter:title"       content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image"       content={OG_IMAGE}>

    <!-- ===== Structured Data (JSON-LD) ===== -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "BelloTreno",
      "url": "https://bellotreno.org",
      "description": "Orari e stato in tempo reale dei treni italiani: Frecciarossa, Intercity, Regionali. Dati tramite ViaggiaTreno.",
      "applicationCategory": "TravelApplication",
      "operatingSystem": "Web",
      "inLanguage": ["it", "en", "zh-Hans"],
      "isAccessibleForFree": true,
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" },
      "author": { "@type": "Person", "email": "ferrovie@bellotreno.org" }
    }
    </script>

    <!-- ===== Assets ===== -->
    <Font cssVariable="--font-inter" preload={[{ weight: 400, style: "normal", subset: "latin" }]} />
    <Font cssVariable="--font-outfit" preload={[{ weight: 800, style: "normal", subset: "latin" }]} />
    <Font cssVariable="--font-jetbrains-mono" />
    <Font cssVariable="--font-noto-sans-sc" />
    <Font cssVariable="--font-material-symbols-outlined" preload />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <script is:inline set:html={`window.currentLang=${JSON.stringify(locale)};`}></script>
    <script is:inline src={withBuildVersion("/scripts/theme-init.js")}></script>
    {ENABLE_UMAMI && (
        <script
            is:inline
            defer
            src={UMAMI_SCRIPT_URL}
            data-website-id={UMAMI_WEBSITE_ID}
            data-domains={UMAMI_DOMAINS}
            data-do-not-track="true"
            data-exclude-search="true"
        ></script>
    )}
    <ClientRouter />
    <slot name="head" />
</head>
<body>
    <div class="aurora-bg" transition:persist="aurora-bg" aria-hidden="true"></div>
    <div style="position: relative; z-index: 1; flex: 1; display: flex; flex-direction: column;">
        <Navbar locale={locale} currentPath={currentPathWithSearch} />
        <BackToTop />
        <slot />
        <Footer locale={locale} />
    </div>

    <script is:inline src={withBuildVersion("/scripts/config.js")}></script>
    <script is:inline src={withBuildVersion("/scripts/i18n.js")}></script>
    <script is:inline src={withBuildVersion("/scripts/common.js")}></script>
    {pageScripts.map((src) => <script is:inline src={withBuildVersion(src)}></script>)}
    <slot name="scripts" />
</body>
</html>

