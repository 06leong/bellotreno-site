{
  "name": "bellotreno-site",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=24.11.1",
    "npm": ">=11.6.2"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "check": "npm run check:js && npm run check:types && npm run test:js && npm run check:i18n && npm run check:python",
    "check:js": "node scripts/check-js-syntax.mjs",
    "check:types": "npm run check:types:normalizers && npm run check:types:functions && npm run check:types:node && npm run check:types:client",
    "check:types:normalizers": "tsc -p tsconfig.normalizers.json",
    "check:types:functions": "tsc -p tsconfig.functions.json",
    "check:types:node": "tsc -p tsconfig.node.json",
    "check:types:client": "tsc -p tsconfig.client.json",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check:python": "python -m py_compile rfi-proxy/app.py rfi-proxy/statistics/app.py && python -m unittest discover -s tests/python",
    "test:js": "node --import tsx --test tests/js/*.test.ts",
    "audit:innerhtml": "node scripts/audit-innerhtml.mjs",
    "preview": "astro preview",
    "astro": "astro"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260601.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.9.1",
    "astro": "^6.3.8",
    "daisyui": "^5.5.20",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "crypto-js": "^4.2.0"
  }
}
