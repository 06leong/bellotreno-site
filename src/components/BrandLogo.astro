---
interface Props {
    class?: string;
    label?: string;
}

const { class: className = '', label = 'BelloTreno' } = Astro.props;
---

<svg
    class:list={['brand-wordmark', className]}
    viewBox="0 0 392 96"
    role="img"
    aria-label={label}
    focusable="false"
    xmlns="http://www.w3.org/2000/svg">
    <text
        x="0"
        y="70"
        class="brand-wordmark-bello"
        font-family="var(--app-font-heading), Outfit, Inter, Segoe UI, Arial, sans-serif"
        font-size="68"
        font-weight="850"
        letter-spacing="-1">
        Bello
    </text>
    <text
        x="176"
        y="70"
        class="brand-wordmark-treno"
        font-family="var(--app-font-heading), Outfit, Inter, Segoe UI, Arial, sans-serif"
        font-size="68"
        font-weight="850"
        letter-spacing="-1">
        Treno
    </text>
</svg>
