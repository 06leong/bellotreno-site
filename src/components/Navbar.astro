---

<nav class="navbar fixed top-0 w-full z-50 bg-base-100/90 backdrop-blur border-b border-base-200 justify-end gap-1 sm:gap-2 px-3 sm:px-4 shadow-sm min-h-0 h-14">
    <a href="/" data-i18n="nav_home" class="btn btn-ghost btn-sm rounded-btn text-[0.95rem] font-normal">首页</a>
    <a href="/infomobilita" data-i18n="nav_infomobilita" class="btn btn-ghost btn-sm rounded-btn text-[0.95rem] font-normal">出行信息</a>
    <a href="/about" data-i18n="nav_about" class="btn btn-ghost btn-sm rounded-btn text-[0.95rem] font-normal">关于</a>
    
    <div class="dropdown dropdown-end">
        <div tabindex="0" role="button" class="btn btn-ghost btn-sm rounded-btn px-2">
            <span class="material-symbols-outlined text-[1.25rem]">language</span>
            <span id="currentLang" class="hidden">CN</span>
        </div>
        <ul tabindex="0" id="langMenu" class="dropdown-content menu bg-base-100 rounded-box z-[1] min-w-max p-2 shadow-lg border border-base-200 mt-2">
            <li><a class="justify-center text-center" data-lang="zh" onclick="changeLang('zh'); document.activeElement.blur(); event.stopPropagation();">Chinese</a></li>
            <li><a class="justify-center text-center" data-lang="en" onclick="changeLang('en'); document.activeElement.blur(); event.stopPropagation();">English</a></li>
            <li><a class="justify-center text-center" data-lang="it" onclick="changeLang('it'); document.activeElement.blur(); event.stopPropagation();">Italiano</a></li>
        </ul>
    </div>
    
    <div class="dropdown dropdown-end">
        <div tabindex="0" role="button" class="btn btn-ghost btn-sm rounded-btn px-2">
            <span class="material-symbols-outlined text-[1.25rem]" id="currentThemeIcon"></span>
            <script is:inline>
                (function() {
                    var t = localStorage.getItem('theme') || 'auto';
                    var i = 'contrast';
                    if (t === 'light') i = 'light_mode';
                    if (t === 'dark') i = 'dark_mode';
                    document.getElementById('currentThemeIcon').innerText = i;
                })();
            </script>
        </div>
        <ul tabindex="0" id="themeMenu" class="dropdown-content menu bg-base-100 rounded-box z-[1] min-w-max p-2 shadow-lg border border-base-200 mt-2">
            <li>
                <a onclick="changeTheme('auto'); document.activeElement.blur(); event.stopPropagation();" class="flex justify-center items-center gap-2">
                    <span class="material-symbols-outlined text-[1.1rem]">contrast</span>
                    <span data-i18n="theme_auto" class="text-center">跟随系统</span>
                </a>
            </li>
            <li>
                <a onclick="changeTheme('light'); document.activeElement.blur(); event.stopPropagation();" class="flex justify-center items-center gap-2">
                    <span class="material-symbols-outlined text-[1.1rem]">light_mode</span>
                    <span data-i18n="theme_light" class="text-center">浅色模式</span>
                </a>
            </li>
            <li>
                <a onclick="changeTheme('dark'); document.activeElement.blur(); event.stopPropagation();" class="flex justify-center items-center gap-2">
                    <span class="material-symbols-outlined text-[1.1rem]">dark_mode</span>
                    <span data-i18n="theme_dark" class="text-center">深色模式</span>
                </a>
            </li>
        </ul>
    </div>
</nav>
