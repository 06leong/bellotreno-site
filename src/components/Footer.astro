---
import { t, type Locale } from '../lib/i18n';

interface Props {
    locale: Locale;
}

const { locale } = Astro.props;
---

<footer>
    <div class="footer-content">
        <span data-i18n="footer">{t(locale, 'footer')}</span>
        <div class="visitor-stats">
            <span id="visitorCount"></span>
        </div>
    </div>
</footer>
