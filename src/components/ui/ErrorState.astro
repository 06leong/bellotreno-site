---
interface Props {
  icon?: string;
  title?: string;
  message?: string;
  class?: string;
}

const { icon = 'error', title, message, class: className = '' } = Astro.props;
---

<div class:list={['bt-state', 'bt-error-state', className]} role="status">
  <span class="material-symbols-outlined" aria-hidden="true">{icon}</span>
  {title && <strong>{title}</strong>}
  {message && <p>{message}</p>}
  <slot />
</div>
