---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
    title="Infomobilità - BelloTreno"
    description="Avvisi e aggiornamenti in tempo reale dell'infomobilità ferroviaria RFI. Notizie su scioperi, lavori e perturbazioni su tutta la rete ferroviaria italiana.">
    <Fragment slot="head"></Fragment>
    <Fragment slot="scripts">
        <script>
            import '../client/infomobilita.ts';
        </script>
    </Fragment>

    <div class="container">
        <div class="text-center mt-10 mb-6">
            <h1
                class="text-[2.5rem] font-bold mb-6 text-primary"
                data-i18n="nav_infomobilita">出行信息</h1>

            <div class="infomobilita-controls flex flex-col items-center gap-6">
                <div class="flex justify-center mx-auto w-[480px] max-w-full bg-base-200/50 p-1 rounded-full border border-base-200 shadow-sm backdrop-blur">
                    <button
                        id="modeUpdatesBtn"
                        type="button"
                        class="board-tab active flex-1 flex items-center justify-center gap-1.5 py-2 px-4 text-sm font-medium rounded-full cursor-pointer transition-all">
                        <span class="material-symbols-outlined text-[1.25rem]">dynamic_feed</span>
                        <span data-i18n="info_updates">实时更新</span>
                    </button>
                    <button
                        id="modeNoticesBtn"
                        type="button"
                        class="board-tab flex-1 flex items-center justify-center gap-1.5 py-2 px-4 text-sm font-medium rounded-full cursor-pointer transition-all">
                        <span class="material-symbols-outlined text-[1.25rem]">campaign</span>
                        <span data-i18n="info_notices">旅行者须知</span>
                    </button>
                </div>

                <div class="dropdown w-[480px] max-w-full mx-auto" id="regionDropdown">
                    <div tabindex="0" role="button" class="btn btn-lg w-full bg-base-100/65 backdrop-blur-3xl shadow-glass custom-region-dropdown focus:outline-none focus:border-primary transition-all font-medium rounded-full flex justify-center hover:bg-base-100/75 h-14 min-h-[3.5rem]">
                        <span id="regionBtnText" data-i18n="region_all" class="text-[1.125rem]">所有大区</span>
                        <span class="material-symbols-outlined absolute right-5 opacity-70">expand_more</span>
                    </div>
                    <ul tabindex="0" class="dropdown-content z-[2] menu p-2 shadow-glass bg-base-100/80 backdrop-blur-3xl border border-base-content/10 rounded-box w-full max-h-64 flex-nowrap overflow-y-auto mt-2">
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="all" data-i18n="region_all">所有大区</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="abruzzo" data-i18n="region_abruzzo">Abruzzo</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="basilicata" data-i18n="region_basilicata">Basilicata</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="calabria" data-i18n="region_calabria">Calabria</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="campania" data-i18n="region_campania">Campania</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="emilia_romagna" data-i18n="region_emilia_romagna">Emilia Romagna</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="friuli_venezia_giulia" data-i18n="region_friuli_venezia_giulia">Friuli Venezia Giulia</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="lazio" data-i18n="region_lazio">Lazio</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="liguria" data-i18n="region_liguria">Liguria</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="lombardia" data-i18n="region_lombardia">Lombardia</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="marche" data-i18n="region_marche">Marche</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="molise" data-i18n="region_molise">Molise</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="piemonte" data-i18n="region_piemonte">Piemonte</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="puglia" data-i18n="region_puglia">Puglia</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="sardegna" data-i18n="region_sardegna">Sardegna</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="sicilia" data-i18n="region_sicilia">Sicilia</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="toscana" data-i18n="region_toscana">Toscana</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="trentino_alto_adige" data-i18n="region_trentino_alto_adige">Trentino Alto Adige</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="umbria" data-i18n="region_umbria">Umbria</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="valle_d_aosta" data-i18n="region_valle_d_aosta">Valle d'Aosta</a></li>
                        <li><a class="justify-center text-center py-3 text-base" data-region-option data-region="veneto" data-i18n="region_veneto">Veneto</a></li>
                    </ul>
                </div>
            </div>

            <div id="rssResults" class="rss-container mt-10 text-left">
                <div id="infoLoading" style="text-align: center; padding: 40px; display: none;">
                    <span class="loading loading-spinner loading-lg text-primary"></span>
                </div>
                <div id="rssContent"></div>
            </div>
        </div>
    </div>
</BaseLayout>
