---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
    title="BelloTreno — Treni in Tempo Reale"
    description="Cerca treni italiani in tempo reale. Stato, ritardi e percorso completo di Frecciarossa, Intercity, Regionali e altri treni Trenitalia su ViaggiaTreno."
    pageScripts={["/scripts/station.js", "/scripts/swiss.js", "/scripts/main.js"]}>
    <Fragment slot="head"></Fragment>
    <div class="container">
        <div class="text-center mt-12 mb-8 relative z-10">
            <a href="#" class="text-primary inline-block hover:opacity-80 transition-opacity" onclick="goHome(); return false;">
                <h1 class="text-[3.5rem] font-extrabold mb-2 text-primary brand-heading tracking-tight drop-shadow-sm">BelloTreno</h1>
            </a>

            <div id="statsBar" class="grid grid-cols-[1fr_auto_1fr] items-center gap-3 sm:gap-4 mb-4 text-xs sm:text-sm text-base-content/60 transition-opacity duration-500 opacity-0">
                <div class="flex items-center gap-1.5 justify-self-end">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-success"></span>
                    </span>
                    <span id="statsCircolanti">--</span>
                    <span data-i18n="stats_running">趟列车正在运行</span>
                </div>
                <span class="text-base-content/20">|</span>
                <div class="flex items-center gap-1.5 justify-self-start">
                    <span class="inline-flex rounded-full h-2 w-2 bg-base-content/30"></span>
                    <span data-i18n="stats_today_prefix">今日已运行</span>
                    <span id="statsGiorno">--</span>
                    <span data-i18n="stats_today_suffix">趟列车</span>
                </div>
            </div>

            <div class="relative w-full max-w-2xl mx-auto group mt-6 z-10">
                <!-- Glowing effect behind the search bar when focused -->
                <div class="absolute -inset-0.5 bg-gradient-to-r from-primary/30 to-info/30 rounded-full blur opacity-0 group-focus-within:opacity-100 transition duration-500"></div>
                
                <div class="relative flex items-center bg-base-100/65 backdrop-blur-3xl glass-border shadow-glass rounded-full overflow-hidden transition-all duration-300">
                    <button id="searchModeToggle" onclick="switchSearchMode(searchMode === 'train' ? 'station' : 'train')" 
                            class="flex items-center justify-center h-14 w-16 sm:w-20 pl-1 sm:pl-2 flex-shrink-0 gap-0 bg-transparent text-base-content/60 hover:text-primary transition-colors border-r border-base-content/10 outline-none cursor-pointer">
                        <span class="material-symbols-outlined text-[1.4rem]" id="searchIcon">train</span>
                        <span class="material-symbols-outlined text-[1.2rem] -ml-1">arrow_drop_down</span>
                    </button>
                    
                    <input type="text" id="trainSearch" 
                           class="flex-1 h-14 px-4 sm:px-6 text-lg bg-transparent border-none focus:outline-none focus:ring-0 text-base-content placeholder-base-content/40 tabular-nums w-full" 
                           placeholder="" autocomplete="off" />
                           
                    <div class="pr-4 hidden sm:flex items-center">
                        <kbd class="kbd kbd-sm opacity-40 border-none bg-base-content/10 font-sans tracking-wide">↵ Return</kbd>
                    </div>
                </div>
            </div>

            <div id="recentSearchesContainer" class="recent-searches-container" style="display: none;">
                <div class="recent-searches-label">
                    <span class="material-symbols-outlined">history</span>
                    <span data-i18n="recent_searches">最近搜索</span>
                </div>
                <div id="recentSearchesChips" class="recent-searches-chips"></div>
            </div>
        </div>

        <div id="disambiguation">
            <h3 style="margin-top:0;" class="text-primary" data-i18n="disambiguation_title">检测到多个班次，请选择：</h3>
            <div id="choicesList"></div>
        </div>

        <div id="scTooltip" class="sc-tooltip"></div>
        <div id="results">
            <div id="trainCard" class="train-header"></div>
            <div id="smartCaringCard" class="sc-card" style="display:none;"></div>
            <div id="swissFormationCard" class="swiss-card" style="display:none;"></div>
            <div class="timeline-container">
                <div id="timelineBody"></div>
            </div>
        </div>
    </div>
</BaseLayout>
