---
import { Font } from 'astro:assets';
---

<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>BelloTreno - 404 Not Found</title>
    <meta name="robots" content="noindex, nofollow">
    <Font cssVariable="--font-share-tech-mono" preload />
    
    <style is:global>
        :root {
            --bg-color: #050505;
            --main-color: #33ff00;
            --dim-color: #005500;
            --glow: rgba(51, 255, 0, 0.5);
            --scanline: rgba(0, 0, 0, 0.5);
        }

        * { box-sizing: border-box; }

        body {
            background-color: var(--bg-color);
            color: var(--main-color);
            font-family: var(--font-share-tech-mono), monospace;
            margin: 0;
            padding: 0;
            min-height: 100vh;
            width: 100vw;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            overflow-x: hidden;
            text-transform: uppercase;
            transition: background-color 0.3s, color 0.3s;
        }

        body::before {
            content: " ";
            display: block;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            right: 0;
            background: linear-gradient(
                to bottom,
                rgba(0,0,0,0) 50%,
                var(--scanline) 50%
            );
            background-size: 100% 4px;
            z-index: 1;
            pointer-events: none;
        }

        .main-content {
            flex: 1;
            width: 100%;
            z-index: 10;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px 10px;
        }

        /* ASCII Art */
        .ascii-art {
            color: var(--main-color);
            font-family: 'Courier New', Courier, monospace;
            font-weight: 900;
            white-space: pre;
            text-align: center;
            line-height: 1; 
            letter-spacing: 0;
            font-size: clamp(6px, 1.4vw, 16px);
            text-shadow: 0 0 5px var(--glow);
            margin-bottom: 3vh;
            transform: translateZ(0);
        }

        .welcome-line {
            font-size: clamp(1rem, 3vw, 1.5rem);
            letter-spacing: 2px;
            margin-bottom: 4vh; 
            text-align: center;
            text-shadow: 0 0 5px var(--glow);
            border: none;
        }

        .cursor-title {
            display: inline-block;
            width: 10px;
            height: 1em;
            background-color: var(--main-color);
            animation: blink 1s step-end infinite;
            vertical-align: text-bottom;
            margin-left: 5px;
            box-shadow: 0 0 5px var(--glow);
        }


        .window-frame {
            width: 90%;
            max-width: 480px; 
            border: 2px solid var(--main-color);
            background-color: var(--bg-color); 
            box-shadow: 6px 6px 0px rgba(0,0,0,0.4);
            margin-bottom: 4vh; 
            position: relative;
            z-index: 20;
            display: flex;
            flex-direction: column;
        }


        .window-header {
            background-color: var(--main-color);
            color: var(--bg-color);
            padding: 2px 6px;
            font-family: 'Courier New', Courier, monospace; 
            font-size: 13px; 
            font-weight: 900;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .close-btn {
            cursor: pointer;
            font-weight: bold;
            font-family: 'Courier New', Courier, monospace;
            font-size: 13px;
        }

   
        .window-content {
            padding: 12px;
            background-color: var(--bg-color);
            color: var(--main-color);
            font-family: 'Courier New', Courier, monospace;
            font-size: clamp(10px, 2.5vw, 13px);
            line-height: 1.4;
            text-align: left;
            text-transform: none;
            text-shadow: none; 
            opacity: 1;
            min-height: 110px; 
            display: block;
        }

        .cmd-line { margin-bottom: 4px; display: block; word-break: break-all; }
        .cmd-prefix { color: var(--main-color); font-weight: bold; margin-right: 5px; }
        .data-val { color: var(--dim-color); font-weight: bold; }
        
        .log-fail { color: #ff3333; }
        .log-info { color: var(--main-color); }
        .log-warn { color: #ffcc00; }

        .error-wrapper {
            text-align: center;
            margin-top: 1vh;
            z-index: 20;
        }

        .error-code {
            font-size: clamp(5rem, 18vw, 10rem); 
            color: var(--bg-color);
            text-shadow: 
                -2px -2px 0 var(--main-color),  
                2px -2px 0 var(--main-color),
                -2px 2px 0 var(--main-color),
                2px 2px 0 var(--main-color),
                0 0 20px var(--glow);
            margin: 0;
            line-height: 0.9;
        }

        .error-desc {
            font-size: clamp(1.2rem, 4vw, 2rem); 
            background: var(--main-color);
            color: var(--bg-color);
            padding: 4px 15px;
            font-weight: 900;
            display: inline-block;
            margin-top: 10px;
        }

        /* Footer */
        footer {
            color: var(--dim-color);
            font-size: 12px;
            z-index: 20;
            letter-spacing: 1px;
            text-align: center;
            font-weight: 900;
            text-shadow: none;
            padding: 20px 0;
            flex-shrink: 0;
            width: 100%;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0; }
        }
    </style>
</head>
