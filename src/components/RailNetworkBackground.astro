---
import { interchanges, lakes, nodes, routes, terrainBlobs } from '../lib/rail-network-map.js';

const pathFromPoints = (points) => {
    const [first, ...rest] = points;
    return `M${first[0]} ${first[1]}${rest.map(([x, y]) => `L${x} ${y}`).join('')}`;
};
const nodeRadius = {
    normal: 7,
    secondary: 10,
    major: 14,
    hub: 18,
};
---

<svg class="rail-network-map" viewBox="0 0 1600 1000" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <g class="rail-map-background">
        {terrainBlobs.map((blob) => <path class="rail-terrain" d={blob.d} />)}
        {lakes.map((lake) => <path class="rail-water" d={lake.d} />)}
    </g>

    <g class="rail-corridors">
        {routes.map((route) => (
            <path class={`rail-line rail-${route.type}`} d={pathFromPoints(route.points)} />
        ))}
    </g>

    <g class="rail-interchanges">
        {interchanges.map((node) => (
            <rect
                class="rail-interchange"
                x={node.x}
                y={node.y}
                width={node.width}
                height={node.height}
                rx={node.rx}
                transform={node.rotate ? `rotate(${node.rotate} ${node.x + node.width / 2} ${node.y + node.height / 2})` : undefined}
            />
        ))}
    </g>

    <g class="rail-stations">
        {nodes.map((node) => <circle class={`rail-node rail-node-${node.size}`} cx={node.x} cy={node.y} r={nodeRadius[node.size] ?? nodeRadius.normal} />)}
    </g>
</svg>
