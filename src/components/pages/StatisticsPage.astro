---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPageMeta, t, type Locale } from '../../lib/i18n';

interface Props {
    locale: Locale;
}

const { locale } = Astro.props;
const meta = getPageMeta(locale, 'statistics');
---

<BaseLayout
    locale={locale}
    title={meta.title}
    description={meta.description}
    pageScripts={["/scripts/statistics.js"]}>
    <Fragment slot="head"></Fragment>

    <main class="statistics-page container">
        <section class="statistics-header">
            <div>
                <p class="statistics-kicker" data-i18n="statistics_kicker">{t(locale, 'statistics_kicker')}</p>
                <h1 data-i18n="statistics_title">{t(locale, 'statistics_title')}</h1>
                <p data-i18n="statistics_subtitle">{t(locale, 'statistics_subtitle')}</p>
            </div>
            <div class="statistics-controls">
                <label class="statistics-date-field">
                    <span data-i18n="statistics_date">{t(locale, 'statistics_date')}</span>
                    <select id="statisticsDate" class="select select-bordered rounded-full"></select>
                </label>
            </div>
        </section>

        <section id="statisticsStatus" class="statistics-status" hidden></section>

        <section class="statistics-meta-row">
            <div class="statistics-meta-item">
                <span class="material-symbols-outlined">update</span>
                <span data-i18n="statistics_last_updated">{t(locale, 'statistics_last_updated')}</span>
                <strong id="statisticsLastUpdated">--</strong>
            </div>
            <div class="statistics-meta-item">
                <span class="material-symbols-outlined">schedule</span>
                <span data-i18n="statistics_cadence">{t(locale, 'statistics_cadence')}</span>
                <strong id="statisticsCadence">--</strong>
            </div>
            <div class="statistics-meta-item">
                <span class="material-symbols-outlined">location_on</span>
                <span data-i18n="statistics_coverage">{t(locale, 'statistics_coverage')}</span>
                <strong id="statisticsCoverage">--</strong>
            </div>
        </section>

        <section id="statisticsMetrics" class="statistics-metrics" aria-live="polite"></section>

        <section class="statistics-grid">
            <div class="statistics-panel">
                <div class="statistics-panel-head">
                    <h2 data-i18n="statistics_chart_running">{t(locale, 'statistics_chart_running')}</h2>
                </div>
                <div id="statisticsRunningChart" class="statistics-chart-box"></div>
            </div>
            <div class="statistics-panel">
                <div class="statistics-panel-head">
                    <h2 data-i18n="statistics_chart_regular">{t(locale, 'statistics_chart_regular')}</h2>
                </div>
                <div id="statisticsRegularityChart" class="statistics-chart-box"></div>
            </div>
            <div class="statistics-panel">
                <div class="statistics-panel-head">
                    <h2 data-i18n="statistics_chart_punctuality">{t(locale, 'statistics_chart_punctuality')}</h2>
                </div>
                <div id="statisticsPunctualityChart" class="statistics-chart-box"></div>
            </div>
            <div class="statistics-panel">
                <div class="statistics-panel-head">
                    <h2 data-i18n="statistics_chart_categories">{t(locale, 'statistics_chart_categories')}</h2>
                </div>
                <div id="statisticsCategoryChart" class="statistics-chart-box"></div>
            </div>
        </section>

        <section class="statistics-panel statistics-search-panel">
            <div class="statistics-panel-head statistics-query-head">
                <h2 data-i18n="statistics_query_title">{t(locale, 'statistics_query_title')}</h2>
            </div>

            <div class="statistics-tabs" role="tablist">
                <button type="button" class="statistics-tab active" data-stat-view="trains" data-i18n="statistics_tab_trains">{t(locale, 'statistics_tab_trains')}</button>
                <button type="button" class="statistics-tab" data-stat-view="stations" data-i18n="statistics_tab_stations">{t(locale, 'statistics_tab_stations')}</button>
                <button type="button" class="statistics-tab" data-stat-view="relations" data-i18n="statistics_tab_relations">{t(locale, 'statistics_tab_relations')}</button>
                <button type="button" class="statistics-tab" data-stat-view="ranking" data-i18n="statistics_tab_ranking">{t(locale, 'statistics_tab_ranking')}</button>
            </div>

            <div class="statistics-filter-grid">
                <input id="statisticsSearch" class="input input-bordered rounded-full" type="search" autocomplete="off" data-i18n="statistics_search_placeholder" placeholder={t(locale, 'statistics_search_placeholder')}>
                <select id="statisticsCategory" class="select select-bordered rounded-full">
                    <option value="" data-i18n="statistics_all_categories">{t(locale, 'statistics_all_categories')}</option>
                </select>
                <select id="statisticsStatusFilter" class="select select-bordered rounded-full">
                    <option value="" data-i18n="statistics_all_statuses">{t(locale, 'statistics_all_statuses')}</option>
                    <option value="regular" data-i18n="statistics_status_regular">{t(locale, 'statistics_status_regular')}</option>
                    <option value="delayed" data-i18n="statistics_status_delayed">{t(locale, 'statistics_status_delayed')}</option>
                    <option value="not_departed" data-i18n="statistics_status_not_departed">{t(locale, 'statistics_status_not_departed')}</option>
                    <option value="cancelled" data-i18n="statistics_status_cancelled">{t(locale, 'statistics_status_cancelled')}</option>
                    <option value="rescheduled" data-i18n="statistics_status_rescheduled">{t(locale, 'statistics_status_rescheduled')}</option>
                </select>
            </div>

            <div id="statisticsTableStatus" class="statistics-table-status"></div>
            <div class="statistics-table-wrap">
                <table class="statistics-table">
                    <thead id="statisticsTableHead"></thead>
                    <tbody id="statisticsTableBody"></tbody>
                </table>
            </div>
            <div class="statistics-pagination">
                <button id="statisticsPrev" class="btn btn-sm rounded-full" type="button">
                    <span class="material-symbols-outlined text-[1rem]">chevron_left</span>
                    <span data-i18n="statistics_prev">{t(locale, 'statistics_prev')}</span>
                </button>
                <span id="statisticsPageInfo">--</span>
                <button id="statisticsNext" class="btn btn-sm rounded-full" type="button">
                    <span data-i18n="statistics_next">{t(locale, 'statistics_next')}</span>
                    <span class="material-symbols-outlined text-[1rem]">chevron_right</span>
                </button>
            </div>
        </section>

        <section class="statistics-disclaimer">
            <span class="material-symbols-outlined">info</span>
            <span data-i18n="statistics_disclaimer">{t(locale, 'statistics_disclaimer')}</span>
        </section>
    </main>
</BaseLayout>
