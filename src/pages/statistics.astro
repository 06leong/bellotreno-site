---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
    title="Statistiche ferroviarie italiane - BelloTreno"
    description="Statistiche giornaliere dei treni italiani monitorati da BelloTreno: puntualita, ritardi, cancellazioni, categorie e andamento della circolazione."
    pageScripts={["/scripts/statistics.js"]}>
    <Fragment slot="head"></Fragment>

    <main class="statistics-page container">
        <section class="statistics-header">
            <div>
                <p class="statistics-kicker" data-i18n="statistics_kicker">ViaggiaTreno observable data</p>
                <h1 data-i18n="statistics_title">Railway Statistics</h1>
                <p data-i18n="statistics_subtitle">Daily operational statistics based on trains visible through ViaggiaTreno.</p>
            </div>
            <div class="statistics-controls">
                <label class="statistics-date-field">
                    <span data-i18n="statistics_date">Date</span>
                    <select id="statisticsDate" class="select select-bordered rounded-full"></select>
                </label>
            </div>
        </section>

        <section id="statisticsStatus" class="statistics-status" hidden></section>

        <section class="statistics-meta-row">
            <div class="statistics-meta-item">
                <span class="material-symbols-outlined">update</span>
                <span data-i18n="statistics_last_updated">Last updated</span>
                <strong id="statisticsLastUpdated">--</strong>
            </div>
            <div class="statistics-meta-item">
                <span class="material-symbols-outlined">schedule</span>
                <span data-i18n="statistics_cadence">Sampling</span>
                <strong id="statisticsCadence">--</strong>
            </div>
            <div class="statistics-meta-item">
                <span class="material-symbols-outlined">location_on</span>
                <span data-i18n="statistics_coverage">Coverage</span>
                <strong id="statisticsCoverage">--</strong>
            </div>
        </section>

        <section id="statisticsMetrics" class="statistics-metrics" aria-live="polite"></section>

        <section class="statistics-grid">
            <div class="statistics-panel">
                <div class="statistics-panel-head">
                    <h2 data-i18n="statistics_chart_running">Trains in circulation</h2>
                </div>
                <div id="statisticsRunningChart" class="statistics-chart-box"></div>
            </div>
            <div class="statistics-panel">
                <div class="statistics-panel-head">
                    <h2 data-i18n="statistics_chart_regular">Regularity</h2>
                </div>
                <div id="statisticsRegularityChart" class="statistics-chart-box"></div>
            </div>
            <div class="statistics-panel">
                <div class="statistics-panel-head">
                    <h2 data-i18n="statistics_chart_punctuality">Punctuality</h2>
                </div>
                <div id="statisticsPunctualityChart" class="statistics-chart-box"></div>
            </div>
            <div class="statistics-panel">
                <div class="statistics-panel-head">
                    <h2 data-i18n="statistics_chart_categories">Categories</h2>
                </div>
                <div id="statisticsCategoryChart" class="statistics-chart-box"></div>
            </div>
        </section>

        <section class="statistics-panel statistics-search-panel">
            <div class="statistics-panel-head statistics-query-head">
                <h2 data-i18n="statistics_query_title">Explore statistics</h2>
            </div>

            <div class="statistics-tabs" role="tablist">
                <button type="button" class="statistics-tab active" data-stat-view="trains" data-i18n="statistics_tab_trains">Trains</button>
                <button type="button" class="statistics-tab" data-stat-view="stations" data-i18n="statistics_tab_stations">Stations</button>
                <button type="button" class="statistics-tab" data-stat-view="relations" data-i18n="statistics_tab_relations">Relations</button>
            </div>

            <div class="statistics-filter-grid">
                <input id="statisticsSearch" class="input input-bordered rounded-full" type="search" autocomplete="off" data-i18n="statistics_search_placeholder" placeholder="Search train, station or relation">
                <select id="statisticsCategory" class="select select-bordered rounded-full">
                    <option value="" data-i18n="statistics_all_categories">All categories</option>
                </select>
                <select id="statisticsStatusFilter" class="select select-bordered rounded-full">
                    <option value="" data-i18n="statistics_all_statuses">All statuses</option>
                    <option value="regular" data-i18n="statistics_status_regular">Regular</option>
                    <option value="delayed" data-i18n="statistics_status_delayed">Delayed</option>
                    <option value="not_departed" data-i18n="statistics_status_not_departed">Not Departed</option>
                    <option value="cancelled" data-i18n="statistics_status_cancelled">Cancelled</option>
                    <option value="rescheduled" data-i18n="statistics_status_rescheduled">Rescheduled</option>
                </select>
            </div>

            <div id="statisticsTableStatus" class="statistics-table-status"></div>
            <div class="statistics-table-wrap">
                <table class="statistics-table">
                    <thead id="statisticsTableHead"></thead>
                    <tbody id="statisticsTableBody"></tbody>
                </table>
            </div>
            <div class="statistics-pagination">
                <button id="statisticsPrev" class="btn btn-sm rounded-full" type="button">
                    <span class="material-symbols-outlined text-[1rem]">chevron_left</span>
                    <span data-i18n="statistics_prev">Previous</span>
                </button>
                <span id="statisticsPageInfo">--</span>
                <button id="statisticsNext" class="btn btn-sm rounded-full" type="button">
                    <span data-i18n="statistics_next">Next</span>
                    <span class="material-symbols-outlined text-[1rem]">chevron_right</span>
                </button>
            </div>
        </section>

        <section class="statistics-disclaimer">
            <span class="material-symbols-outlined">info</span>
            <span data-i18n="statistics_disclaimer">Statistics are derived from observable ViaggiaTreno data and are not official full-network figures.</span>
        </section>
    </main>
</BaseLayout>
