  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": false,
    "noImplicitAny": true,
    "strictNullChecks": false,
    "useUnknownInCatchVariables": true
  },
  "include": [
    "src/types/**/*.d.ts",
    "src/client/**/*.ts"
  ]
}
