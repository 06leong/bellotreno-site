---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
    title="About - BelloTreno"
    description="BelloTreno is a personal railway data project for Italian train status, station boards, travel notices, and observable statistics.">
    <Fragment slot="scripts">
        <script>
            import '../client/about.ts';
        </script>
    </Fragment>

    <main class="w-full max-w-4xl mx-auto px-4 py-8 md:py-12 mt-16 md:mt-24">
        <article class="about-card prose max-w-none bg-base-100/65 backdrop-blur-3xl p-8 md:p-12 rounded-[2rem] shadow-glass border border-base-content/10 mx-auto transition-all duration-300 hover:bg-base-100/75 shadow-sm">
            <h1 data-i18n="about_title" class="text-primary mb-8 font-bold">About BelloTreno</h1>

            <section data-about-section="intro" class="text-base-content/80 leading-relaxed"></section>

            <h2 data-i18n="about_roadmap" class="text-base-content mt-10 mb-6 font-semibold">Roadmap</h2>
            <section data-about-section="roadmap" class="text-base-content/80 leading-relaxed"></section>

            <h2 data-i18n="about_official" class="text-base-content mt-10 mb-6 font-semibold">Official railway information</h2>
            <section data-about-section="official" class="text-base-content/80 leading-relaxed"></section>

            <h2 data-i18n="about_disclaimer" class="text-base-content mt-10 mb-6 font-semibold">Disclaimer</h2>
            <section data-about-section="disclaimer" class="text-base-content/80 leading-relaxed"></section>

            <h2 data-i18n="about_technical" class="text-base-content mt-10 mb-6 font-semibold">Technical references</h2>
            <section data-about-section="technical" class="text-base-content/80 leading-relaxed"></section>
        </article>
    </main>
</BaseLayout>
