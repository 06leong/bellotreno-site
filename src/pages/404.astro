---
import { Font } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
    title="BelloTreno - 404 Not Found"
    description="BelloTreno page not found."
    robots="noindex, nofollow">
    <Fragment slot="head">
        <Font cssVariable="--font-share-tech-mono" preload />
    </Fragment>

    <main class="container bt-404-page">
        <section class="bt-terminal-panel" aria-labelledby="not-found-title">
            <div class="bt-terminal-header">
                <span>BELLOTRENO CONTROL NODE</span>
                <span>HTTP 404</span>
            </div>
            <div class="bt-terminal-body" id="terminal-body">
                <span class="cmd-prefix">root@bellotreno:~#</span> init_connection...
            </div>
        </section>

        <section class="bt-404-copy">
            <p class="bt-page-eyebrow">Route unavailable</p>
            <h1 id="not-found-title">404</h1>
            <p>The requested page is outside the current timetable network.</p>
            <a class="bt-404-action" href="/">
                <span class="material-symbols-outlined" aria-hidden="true">train</span>
                <span>Return to BelloTreno</span>
            </a>
        </section>
    </main>

    <script is:inline data-astro-rerun slot="scripts">
        document.addEventListener("astro:page-load", function() {
            const term = document.getElementById('terminal-body');
            if (!term) return;

            const ua = navigator.userAgent;
            const escapeHtml = (value) => String(value).replace(/[&<>"']/g, (char) => ({
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#39;'
            }[char]));

            let deviceModel = "Unknown Device";
            if (/iPhone/.test(ua)) deviceModel = "iPhone";
            else if (/iPad/.test(ua)) deviceModel = "iPad";
            else if (/Android/.test(ua)) {
                const match = ua.match(/Android.*?; (.*?)\)/);
                deviceModel = match && match[1] ? match[1].split('Build')[0].trim() : "Android Device";
            } else if (/Mac/.test(ua)) deviceModel = "Macintosh";
            else if (/Win/.test(ua)) deviceModel = "Windows PC";
            else if (/Linux/.test(ua)) deviceModel = "Linux Machine";

            let browser = "Web Client";
            if (/Chrome/.test(ua) && !/Edge/.test(ua)) browser = "Chrome";
            else if (/Firefox/.test(ua)) browser = "Firefox";
            else if (/Safari/.test(ua)) browser = "Safari";
            else if (/Edge/.test(ua)) browser = "Edge";

            const screenRes = `${window.screen.width}x${window.screen.height}`;
            term.innerHTML = `
                <span class="cmd-prefix">root@bellotreno:~#</span> client_identify<br>
                <span class="cmd-line">Connection established from <span class="data-val">${escapeHtml(deviceModel)}</span></span>
                <span class="cmd-line">Client Agent: <span class="data-val">${escapeHtml(browser)}</span></span>
                <span class="cmd-line">Display Geometry: <span class="data-val">${escapeHtml(screenRes)}</span></span>
                <br>
                <span class="cmd-prefix">root@bellotreno:~#</span> resolve_route<br>
                <span class="cmd-line log-warn">> [WARN] REQUESTED ROUTE NOT FOUND</span>
                <span class="cmd-line log-info">> [INFO] FALLBACK ENTRYPOINT AVAILABLE: /</span>
            `;
        });
    </script>
</BaseLayout>
